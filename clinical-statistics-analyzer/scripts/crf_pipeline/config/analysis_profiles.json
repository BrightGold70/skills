{
  "version": "1.0",
  "description": "R script routing per disease type for the analysis orchestrator",
  "profiles": {
    "aml": {
      "scripts": [
        {
          "name": "02_table1.R",
          "args": ["{dataset}"],
          "required": true,
          "expected_outputs": ["Table1_Baseline_Characteristics.docx"],
          "description": "Baseline characteristics table"
        },
        {
          "name": "05_safety.R",
          "args": ["{dataset}"],
          "required": true,
          "expected_outputs": ["Safety_Summary_Table.docx"],
          "description": "Adverse event safety summary"
        },
        {
          "name": "03_efficacy.R",
          "args": ["{dataset}", "{outcome_var}", "--disease", "{disease}"],
          "required": true,
          "expected_outputs": ["Efficacy_Table.docx", "Forest_Efficacy.eps"],
          "description": "Efficacy analysis with response rates"
        },
        {
          "name": "04_survival.R",
          "args": ["{dataset}", "{time_var}", "{status_var}", "--disease", "{disease}"],
          "required": true,
          "expected_outputs": ["KM_OS.eps", "KM_PFS.eps"],
          "description": "Kaplan-Meier survival analysis",
          "run_variants": [
            {"time_var": "OS_months", "status_var": "OS_status", "suffix": "OS"},
            {"time_var": "PFS_months", "status_var": "PFS_status", "suffix": "PFS"}
          ]
        },
        {
          "name": "20_aml_eln_risk.R",
          "args": ["{dataset}"],
          "required": false,
          "expected_outputs": ["AML_ELN2022_Risk.docx", "AML_ELN2022_Risk.eps"],
          "description": "AML ELN 2022 risk stratification"
        },
        {
          "name": "21_aml_composite_response.R",
          "args": ["{dataset}"],
          "required": false,
          "expected_outputs": ["AML_Composite_Response.docx", "AML_Composite_Waterfall.eps"],
          "description": "AML composite response analysis"
        }
      ],
      "default_time_var": "OS_months",
      "default_status_var": "OS_status",
      "default_outcome_var": "Response_numeric"
    },
    "cml": {
      "scripts": [
        {
          "name": "02_table1.R",
          "args": ["{dataset}"],
          "required": true,
          "expected_outputs": ["Table1_Baseline_Characteristics.docx"],
          "description": "Baseline characteristics table"
        },
        {
          "name": "05_safety.R",
