          ]
        },
        {
          "name": "24_hct_gvhd_analysis.R",
          "args": ["{dataset}"],
          "required": false,
          "expected_outputs": ["HCT_GVHD.docx", "HCT_GVHD_CI.eps", "HCT_GRFS.eps"],
          "description": "HCT GVHD and GRFS analysis"
        }
      ],
      "default_time_var": "OS_months",
      "default_status_var": "OS_status",
      "default_outcome_var": "Response"
    }
  }
