        },
        {
          "name": "28_cml_resistance.R",
          "args": ["{dataset}"],
          "required": false,
          "expected_outputs": ["CML_Resistance_Mutations.docx", "CML_Resistance_Timeline.eps"],
          "description": "ABL1 kinase domain resistance mutation tracking"
        },
        {
          "name": "29_cml_tfr_deep.R",
          "args": ["{dataset}"],
          "required": false,
          "expected_outputs": ["CML_TFR_Deep_Analysis.docx", "CML_TFR_Relapse_Kinetics.eps", "CML_TFR_MMR_Loss_KM.eps", "CML_TFR_MMR_Loss_CI.eps"],
          "description": "Deep TFR analysis with relapse kinetics and competing risks"
        }
      ],
      "default_time_var": "OS_months",
      "default_status_var": "OS_status",
      "default_outcome_var": "MMR_achieved"
    },
