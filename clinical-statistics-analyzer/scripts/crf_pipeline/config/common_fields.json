        {"crf_field": "Platelet count", "variable": "plt1", "type": "numeric", "extraction_method": "regex", "patterns": ["Platelet|plt[:\\s]*(\\d+\\.?\\d*)"]},
        {"crf_field": "Bone marrow blast %", "variable": "blast1", "type": "numeric", "extraction_method": "regex", "patterns": ["Blast|blast[:\\s]*(\\d+\\.?\\d*)"]}
