        {"crf_field": "Age", "variable": "age", "type": "numeric", "extraction_method": "template", "required": true, "patterns": ["(?:Age|ë‚کى‌´|ى„¸)[:\\s]*(\\d+)", "(\\d+)\\s*(?:ى„¸|years?|yr)"]},
        {"crf_field": "Gender", "variable": "gender", "type": "categorical", "extraction_method": "template", "sps_code": true, "patterns": ["(?:Gender|Sex|ى„±ë³„)[:\\s]*(Male|Female|ë‚¨ى„±|ى—¬ى„±|M|F|ë‚¨|ى—¬)", "([MF]ale)?"]}
      ]
    },
