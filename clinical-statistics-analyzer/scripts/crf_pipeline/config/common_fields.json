        {"crf_field": "Survival status", "variable": "alive", "type": "categorical", "extraction_method": "template", "required": true, "sps_code": true, "patterns": ["(?:Survival status|alive)[:\\s]*(Alive|Dead|ىƒ‌ى،´|ى‚¬ë§‌|Yes|No)", "(Alive|Dead|ىƒ‌ى،´|ى‚¬ë§‌)"]},
        {"crf_field": "Date of death", "variable": "date_death", "type": "date", "extraction_method": "ocr"},
        {"crf_field": "Cause of death", "variable": "cause_death", "type": "categorical", "extraction_method": "llm"},
        {"crf_field": "Relapse", "variable": "relapse", "type": "categorical", "extraction_method": "template"},
        {"crf_field": "Relapse date", "variable": "relapse_date", "type": "date", "extraction_method": "ocr"},
