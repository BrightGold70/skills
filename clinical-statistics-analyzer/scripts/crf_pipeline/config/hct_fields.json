{
  "version": "2.0",
  "disease": "hct",
  "description": "HCT-specific fields overlaying common_fields",
  "sections": {
    "disease_info": {
      "description": "HCT diagnosis information",
      "fields": [
        {"crf_field": "Primary diagnosis for HCT", "variable": "diag", "type": "categorical", "extraction_method": "template"},
        {"crf_field": "Disease status at HCT", "variable": "disease_status_hct", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["CR1", "CR2", "CR3+", "Active disease", "Primary refractory"]}
      ]
    },
    "donor": {
      "description": "Donor characteristics",
      "fields": [
        {"crf_field": "Donor type", "variable": "donor_type", "type": "categorical", "extraction_method": "template", "sps_code": true, "required": true, "values": ["MSD", "MUD", "MMUD", "Haplo", "CB", "형제", "비혈연", "반일치", "제대혈"], "patterns": ["[Dd]onor[:\\s]*(MSD|MUD|MMUD|Haplo|Haploidentical|CB|Cord blood|형제|비혈연|반일치|제대혈)"]},
        {"crf_field": "Donor age", "variable": "donor_age", "type": "numeric", "extraction_method": "regex", "patterns": ["[Dd]onor.*[Aa]ge[:\\s]*(\\d+)"]},
        {"crf_field": "Donor sex", "variable": "donor_sex", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["Male", "Female", "M", "F"]},
        {"crf_field": "HLA match", "variable": "hla_match", "type": "string", "extraction_method": "template", "patterns": ["HLA[:\\s]*(\\d+/\\d+)", "(\\d+)/\\d+\\s*(?:match|일치)"]},
        {"crf_field": "ABO compatibility", "variable": "abo_compat", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["Compatible", "Minor mismatch", "Major mismatch", "Bidirectional"]},
        {"crf_field": "Sex mismatch (F→M)", "variable": "sex_mismatch", "type": "categorical", "extraction_method": "derived", "sps_code": true, "values": ["Yes", "No"]},
        {"crf_field": "CMV status (donor)", "variable": "cmv_donor", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["Positive", "Negative", "양성", "음성"]},
        {"crf_field": "CMV status (recipient)", "variable": "cmv_recipient", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["Positive", "Negative", "양성", "음성"]}
      ]
    },
    "conditioning": {
      "description": "Conditioning regimen and HCT details",
      "fields": [
        {"crf_field": "Conditioning regimen", "variable": "conditioning", "type": "categorical", "extraction_method": "llm", "required": true},
        {"crf_field": "Conditioning intensity", "variable": "conditioning_intensity", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["MAC", "RIC", "NMA", "골수파괴성", "감량", "비골수파괴성"], "patterns": ["(?:intensity|강도)[:\\s]*(MAC|RIC|NMA|myeloablative|reduced|non-myeloablative)"]},
        {"crf_field": "TBI used", "variable": "tbi_used", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["Yes", "No"]},
        {"crf_field": "TBI dose (Gy)", "variable": "tbi_dose", "type": "numeric", "extraction_method": "regex", "patterns": ["TBI[:\\s]*(\\d+\\.?\\d*)\\s*(?:Gy|cGy)"]},
        {"crf_field": "Stem cell source", "variable": "stem_cell_source", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["PBSC", "BM", "CB", "말초혈", "골수", "제대혈"], "patterns": ["(?:source|줄기세포)[:\\s]*(PBSC|BM|CB|bone marrow|peripheral|cord)"]},
        {"crf_field": "CD34+ dose (x10^6/kg)", "variable": "cd34_dose", "type": "numeric", "extraction_method": "regex", "patterns": ["CD34[:\\s]*(\\d+\\.?\\d*)"]},
        {"crf_field": "GVHD prophylaxis", "variable": "gvhd_prophylaxis", "type": "text", "extraction_method": "llm"},
        {"crf_field": "ATG used", "variable": "atg_used", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["Yes", "No"]},
        {"crf_field": "PTCy used", "variable": "ptcy_used", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["Yes", "No"]}
      ]
    },
    "engraftment": {
      "description": "Engraftment endpoints",
      "fields": [
        {"crf_field": "ANC engraftment date", "variable": "engraft_anc_date", "type": "date", "extraction_method": "ocr", "patterns": ["ANC.*engraft.*date[:\\s]*(\\d{1,2}[-\\/]\\d{1,2}[-\\/]\\d{2,4})"]},
        {"crf_field": "Days to ANC engraftment", "variable": "engraft_anc_days", "type": "numeric", "extraction_method": "regex", "patterns": ["ANC.*engraft.*[Dd]ay[:\\s]*(\\d+)", "(\\d+)\\s*(?:days?|일).*ANC"]},
        {"crf_field": "Platelet engraftment date", "variable": "engraft_plt_date", "type": "date", "extraction_method": "ocr"},
        {"crf_field": "Days to platelet engraftment", "variable": "engraft_plt_days", "type": "numeric", "extraction_method": "regex"},
        {"crf_field": "Primary graft failure", "variable": "graft_failure", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["Yes", "No"]},
        {"crf_field": "Chimerism D+30 (%)", "variable": "chimerism_d30", "type": "numeric", "extraction_method": "regex", "patterns": ["D\\+?30.*chimer[:\\s]*(\\d+\\.?\\d*)", "(\\d+\\.?\\d*)\\s*%.*D\\+?30"]},
        {"crf_field": "Chimerism D+100 (%)", "variable": "chimerism_d100", "type": "numeric", "extraction_method": "regex"},
        {"crf_field": "Full donor chimerism achieved", "variable": "full_donor_chimerism", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["Yes", "No"]}
      ]
    },
    "gvhd": {
      "description": "Graft-versus-host disease",
      "fields": [
        {"crf_field": "Acute GVHD", "variable": "agvhd", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["Yes", "No", "예", "아니오"]},
        {"crf_field": "Acute GVHD grade", "variable": "agvhd_grade", "type": "numeric", "extraction_method": "template", "patterns": ["[Aa]cute.*GVHD.*[Gg]rade[:\\s]*(\\d)", "Grade[:\\s]*(I{1,3}V?|[1-4])"]},
        {"crf_field": "Acute GVHD onset date", "variable": "agvhd_date", "type": "date", "extraction_method": "ocr"},
        {"crf_field": "Acute GVHD organs", "variable": "agvhd_organs", "type": "text", "extraction_method": "llm"},
        {"crf_field": "Chronic GVHD", "variable": "cgvhd", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["Yes", "No", "예", "아니오"]},
        {"crf_field": "Chronic GVHD severity (NIH)", "variable": "cgvhd_severity", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["Mild", "Moderate", "Severe", "경증", "중등증", "중증"]},
        {"crf_field": "Chronic GVHD onset date", "variable": "cgvhd_date", "type": "date", "extraction_method": "ocr"},
        {"crf_field": "Chronic GVHD organs", "variable": "cgvhd_organs", "type": "text", "extraction_method": "llm"},
        {"crf_field": "Steroid refractory GVHD", "variable": "steroid_refractory", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["Yes", "No"]}
      ]
    },
    "outcomes_hct": {
      "description": "HCT-specific composite outcomes",
      "fields": [
        {"crf_field": "Non-relapse mortality", "variable": "nrm", "type": "categorical", "extraction_method": "derived", "sps_code": true, "values": ["Yes", "No"]},
        {"crf_field": "NRM date", "variable": "nrm_date", "type": "date", "extraction_method": "ocr"},
        {"crf_field": "GVHD-free relapse-free survival event", "variable": "grfs_event", "type": "categorical", "extraction_method": "derived", "sps_code": true, "values": ["Yes", "No"]},
        {"crf_field": "GRFS event date", "variable": "grfs_date", "type": "date", "extraction_method": "derived"},
        {"crf_field": "Cause of NRM", "variable": "nrm_cause", "type": "categorical", "extraction_method": "llm", "values": ["GVHD", "Infection", "Organ failure", "VOD/SOS", "Secondary malignancy", "Other"]},
        {"crf_field": "VOD/SOS", "variable": "vod_sos", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["Yes", "No"]},
        {"crf_field": "CMV reactivation", "variable": "cmv_reactivation", "type": "categorical", "extraction_method": "template", "sps_code": true, "values": ["Yes", "No"]}
      ]
    }
  },
  "column_mapping": {
    "conditioning_intensity": "Conditioning",
    "donor_type": "Donor_Type",
    "stem_cell_source": "Stem_Cell_Source",
    "disease_status_hct": "Disease_Status",
    "agvhd": "aGVHD",
    "agvhd_grade": "aGVHD_Grade",
    "cgvhd": "cGVHD",
    "cgvhd_severity": "cGVHD_Severity",
    "hct_date": "Treatment_Start_Date"
  },
  "derived_columns": {
    "OS_months": {
      "type": "date_diff_months",
      "from": "hct_date",
      "to": "date_death",
      "censor": "date_last_fu"
    },
    "PFS_months": {
      "type": "date_diff_months",
      "from": "hct_date",
      "to": "relapse_date",
      "censor": "date_last_fu"
    },
    "OS_status": {
      "type": "recode",
      "source": "alive",
      "mapping": {"1": 0, "2": 1, "Survival": 0, "Dead": 1, "Alive": 0}
    },
    "NRM_status": {
      "type": "recode",
      "source": "nrm",
      "mapping": {"Yes": 1, "No": 0, "1": 1, "2": 0}
    },
    "Age_group": {
      "type": "bin",
      "source": "age",
      "bins": [0, 60, 200],
      "labels": ["<60", ">=60"]
    }
  },
  "spss_value_mapping": {
    "disease_status_hct": {"CR1": 1, "CR2": 2, "CR3+": 3, "Active disease": 4, "Primary refractory": 5, "1": "CR1", "2": "CR2", "3": "CR3+", "4": "Active disease", "5": "Primary refractory"},
    "donor_type": {"MSD": 1, "MUD": 2, "MMUD": 3, "Haplo": 4, "CB": 5, "형제": 1, "비혈연": 2, "반일치": 4, "제대혈": 5, "1": "MSD", "2": "MUD", "3": "MMUD", "4": "Haplo", "5": "CB"},
    "donor_sex": {"Male": 1, "Female": 2, "M": 1, "F": 2, "1": "Male", "2": "Female"},
    "abo_compat": {"Compatible": 0, "Minor mismatch": 1, "Major mismatch": 2, "Bidirectional": 3, "0": "Compatible", "1": "Minor mismatch", "2": "Major mismatch", "3": "Bidirectional"},
    "sex_mismatch": {"Yes": 1, "No": 2, "1": "Yes", "2": "No"},
    "cmv_donor": {"Positive": 1, "Negative": 2, "양성": 1, "음성": 2, "1": "Positive", "2": "Negative"},
    "cmv_recipient": {"Positive": 1, "Negative": 2, "양성": 1, "음성": 2, "1": "Positive", "2": "Negative"},
    "conditioning_intensity": {"MAC": 1, "RIC": 2, "NMA": 3, "골수파괴성": 1, "감량": 2, "비골수파괴성": 3, "1": "MAC", "2": "RIC", "3": "NMA"},
    "tbi_used": {"Yes": 1, "No": 2, "1": "Yes", "2": "No"},
    "stem_cell_source": {"PBSC": 1, "BM": 2, "CB": 3, "말초혈": 1, "골수": 2, "제대혈": 3, "1": "PBSC", "2": "BM", "3": "CB"},
    "atg_used": {"Yes": 1, "No": 2, "1": "Yes", "2": "No"},
    "ptcy_used": {"Yes": 1, "No": 2, "1": "Yes", "2": "No"},
    "graft_failure": {"Yes": 1, "No": 2, "1": "Yes", "2": "No"},
    "full_donor_chimerism": {"Yes": 1, "No": 2, "1": "Yes", "2": "No"},
    "agvhd": {"Yes": 1, "No": 2, "예": 1, "아니오": 2, "1": "Yes", "2": "No"},
    "cgvhd": {"Yes": 1, "No": 2, "예": 1, "아니오": 2, "1": "Yes", "2": "No"},
    "cgvhd_severity": {"Mild": 1, "Moderate": 2, "Severe": 3, "경증": 1, "중등증": 2, "중증": 3, "1": "Mild", "2": "Moderate", "3": "Severe"},
    "steroid_refractory": {"Yes": 1, "No": 2, "1": "Yes", "2": "No"},
    "nrm": {"Yes": 1, "No": 2, "1": "Yes", "2": "No"},
    "grfs_event": {"Yes": 1, "No": 2, "1": "Yes", "2": "No"},
    "nrm_cause": {"GVHD": 1, "Infection": 2, "Organ failure": 3, "VOD/SOS": 4, "Secondary malignancy": 5, "Other": 6, "1": "GVHD", "2": "Infection", "3": "Organ failure", "4": "VOD/SOS", "5": "Secondary malignancy", "6": "Other"},
    "vod_sos": {"Yes": 1, "No": 2, "1": "Yes", "2": "No"},
    "cmv_reactivation": {"Yes": 1, "No": 2, "1": "Yes", "2": "No"}
  },
  "required_fields": ["diag", "donor_type", "conditioning", "hct_date"]
}
