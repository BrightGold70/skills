#!/usr/bin/env bash
printf 'orca %s\n' "$*" >> "${HMAD_STUB_CAPTURE:-/dev/null}"
[ "${HMAD_STUB_FAIL:-}" = "1" ] && { printf '%s' '{"ok":false,"error":"boom"}'; exit 0; }
if [ "${1:-}" = "worktree" ] && [ "${2:-}" = "set" ]; then
  printf '%s' '{"ok":true,"result":{"worktree":{"branch":"refs/heads/main","path":"/x","comment":"c"}}}'
  exit 0
fi
if [ "${1:-}" = "worktree" ] && [ "${2:-}" = "current" ] && [ "${3:-}" = "--json" ]; then
  printf '%s' '{"ok":true,"result":{"worktree":{"branch":"refs/heads/main","path":"/x","comment":"c"}}}'
  exit 0
fi
# J16: `worktree ps` and `terminal list` are DIFFERENT calls that the paneKey
# identity join consumes together, so a single HMAD_STUB_ORCA_STDOUT cannot
# express both. This override is consulted only when explicitly set, so every
# pre-J16 test keeps the shared-stdout behaviour it was written against.
if [ "${1:-}" = "worktree" ] && [ "${2:-}" = "ps" ] && [ -n "${HMAD_STUB_ORCA_WT_PS_STDOUT:-}" ]; then
  printf '%s' "$HMAD_STUB_ORCA_WT_PS_STDOUT"
  exit 0
fi
# J1: `launch` calls `terminal create` and then `terminal list`, and the whole
# point is that they report DIFFERENT handles for the same pane. A single shared
# stdout cannot express that. Consulted only when explicitly set.
if [ "${1:-}" = "terminal" ] && [ "${2:-}" = "create" ] && [ -n "${HMAD_STUB_ORCA_CREATE_STDOUT:-}" ]; then
  printf '%s' "$HMAD_STUB_ORCA_CREATE_STDOUT"
  exit 0
fi
# Default success envelope for un-cased `--json` verbs. Real Orca always returns
# {"ok":true,"result":{…}}; the previous empty-stdout default was unrealistic and
# is now rejected by the wrapper's `_orca_json` ok-check. Only applies when no
# explicit STDOUT/EXIT override and no failure flag is set.
if [ -z "${HMAD_STUB_ORCA_STDOUT:-}" ] && [ "${HMAD_STUB_ORCA_EXIT:-0}" = "0" ]; then
  case " $* " in *" --json "*) printf '%s' '{"ok":true,"result":{}}'; exit 0 ;; esac
fi
[ -n "$HMAD_STUB_ORCA_STDOUT" ] && printf '%s' "$HMAD_STUB_ORCA_STDOUT"
exit "${HMAD_STUB_ORCA_EXIT:-0}"
