{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "h-mad orchestrator_state per-feature schema (v2.2)",
  "type": "object",
  "required": [
    "feature",
    "started_ts",
    "last_completed_phase",
    "current_phase",
    "phase",
    "audit_cycles",
    "iterate_cycles",
    "halt_reason",
    "halt_ts"
  ],
  "properties": {
    "feature": {"type": "string", "minLength": 1},
    "started_ts": {"type": "string", "format": "date-time"},
    "last_completed_phase": {"type": "integer", "minimum": 0, "maximum": 7},
    "current_phase": {"type": "integer", "minimum": 0, "maximum": 7},
    "phase": {"enum": ["step5", "step6", "step7", null]},
    "autonomous_entry_ts": {"type": ["string", "null"], "format": "date-time"},
    "audit_cycles": {
      "type": "object",
      "properties": {
        "plan": {"type": "integer", "minimum": 0},
        "design": {"type": "integer", "minimum": 0},
        "impl_plan": {"type": "integer", "minimum": 0}
      },
      "required": ["plan", "design", "impl_plan"],
      "additionalProperties": false
    },
    "iterate_cycles": {"type": "integer", "minimum": 0},
    "owner_session_id": {
      "description": "Session currently working this feature. Advisory, not a mutex: it lets a second session see the collision instead of discovering it in the git log. Cleared on release.",
      "type": ["string", "null"]
    },
    "owner_heartbeat_ts": {
      "description": "When the owner was last seen. A claim older than the staleness window is treated as abandoned, so a crashed session cannot own a feature permanently.",
      "type": ["string", "null"],
      "format": "date-time"
    },
    "archreview": {
      "description": "Phase 6a-prime outcome. SKIPPED_NO_PANE records that no reviewer pane resolved and the operator elected to proceed; it is never equivalent to READY_TO_MERGE and must surface in the Phase 7 report.",
      "enum": ["READY_TO_MERGE", "WITH_FIXES", "NO", "SKIPPED_NO_PANE"]
    },
    "production_paths_needing_red_tests": {
      "type": "array",
      "items": {"type": "string"}
    },
    "halt_reason": {"type": ["string", "null"]},
    "halt_ts": {"type": ["string", "null"], "format": "date-time"},
    "last_marker": {"type": "string"}
  },
  "additionalProperties": false
}
