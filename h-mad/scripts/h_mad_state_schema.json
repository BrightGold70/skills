{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "h-mad orchestrator_state per-feature schema (v2.2)",
  "type": "object",
  "required": [
    "feature",
    "started_ts",
    "last_completed_phase",
    "current_phase",
    "phase",
    "audit_cycles",
    "iterate_cycles",
    "halt_reason",
    "halt_ts"
  ],
  "properties": {
    "feature": {"type": "string", "minLength": 1},
    "started_ts": {"type": "string", "format": "date-time"},
    "last_completed_phase": {"type": "integer", "minimum": 0, "maximum": 7},
    "current_phase": {"type": "integer", "minimum": 0, "maximum": 7},
    "phase": {"enum": ["step5", "step6", "step7", null]},
    "autonomous_entry_ts": {"type": ["string", "null"], "format": "date-time"},
    "audit_cycles": {
      "type": "object",
      "properties": {
        "plan": {"type": "integer", "minimum": 0},
        "design": {"type": "integer", "minimum": 0},
        "impl_plan": {"type": "integer", "minimum": 0}
      },
      "required": ["plan", "design", "impl_plan"],
      "additionalProperties": false
    },
    "iterate_cycles": {"type": "integer", "minimum": 0},
    "production_paths_needing_red_tests": {
      "type": "array",
      "items": {"type": "string"}
    },
    "halt_reason": {"type": ["string", "null"]},
    "halt_ts": {"type": ["string", "null"], "format": "date-time"},
    "last_marker": {"type": "string"}
  },
  "additionalProperties": false
}
